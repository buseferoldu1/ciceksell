# Bu dosyayi .env.local olarak kopyalayin (yerel) veya degerleri
# Vercel > Settings > Environment Variables altina girin (uretim).
# .env.local ASLA git'e eklenmez.

# --- Yonetici paneli (ZORUNLU) -------------------------------------------
# /admin girisinde kullanacaginiz sifre. Uretimde tanimlanmazsa admin
# paneli tamamen kapali kalir. Uzun ve tahmin edilemez bir deger secin.
ADMIN_KEY=

# --- Veritabani (uretimde ZORUNLU) ---------------------------------------
# Neon/Vercel Postgres baglanti adresi. Tanimli degilse veriler yerelde
# data/*.json dosyalarina yazilir (Vercel'de CALISMAZ - salt okunur).
# Ornek: postgresql://kullanici:sifre@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Gorsel yukleme (uretimde ZORUNLU) -----------------------------------
# Vercel Blob token'i. Tanimli degilse yuklenen gorseller public/uploads
# klasorune yazilir (Vercel'de CALISMAZ).
BLOB_READ_WRITE_TOKEN=

# --- iyzico (odeme sistemi - HENUZ BAGLANMADI) ---------------------------
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Uyelik sistemi (uretimde ZORUNLU) ------------------------------------
# Oturum cerezlerini imzalamak icin kullanilir. Tanimli degilse uretimde
# giris/kaydol calismaz. Uretmek icin:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
